<odoo>
    <record id="view_branch_accounting_report_wizard" model="ir.ui.view">
        <field name="name">branch.accounting.report.wizard.form</field>
        <field name="model">branch.accounting.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Branch Accounting Report">
                <group>
                    <field name="branch_option"/>
                    <field name="branch_ids" widget="many2many_tags" attrs="{'invisible': [('branch_option', '=', 'all')]}"/>
                    <field name="journal_ids" widget="many2many_tags"/>
                    <field name="account_ids" widget="many2many_tags"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button string="Print" type="object" name="action_print_report" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>