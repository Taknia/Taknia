<odoo>
    <record id="view_ai_recommendation_tree" model="ir.ui.view">
        <field name="name">ai.recommendation.tree</field>
        <field name="model">ai.recommendation</field>
        <field name="arch" type="xml">
            <tree string="AI Recommendations">
                <field name="name"/>
                <field name="recommendation_type"/>
                <field name="date"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_ai_recommendation_form" model="ir.ui.view">
        <field name="name">ai.recommendation.form</field>
        <field name="model">ai.recommendation</field>
        <field name="arch" type="xml">
            <form string="AI Recommendation">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="recommendation_type"/>
                            <field name="date"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="recommended_action" nolabel="1"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_execute_recommendation" string="تنفيذ التوصية" type="object" class="oe_highlight"/>
                        <button string="إغلاق" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_recommendation" model="ir.actions.act_window">
        <field name="name">AI Recommendations</field>
        <field name="res_model">ai.recommendation</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p>
                This section displays AI-generated financial recommendations based on your company's data.
                You can review and execute recommendations directly from this interface.
            </p>
        </field>
    </record>

    <menuitem id="menu_ai_recommendation"
              parent="menu_financial_reports"
              action="action_ai_recommendation"
              sequence="20"/>
</odoo>
