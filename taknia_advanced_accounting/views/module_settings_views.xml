<odoo>
    <record id="view_module_settings_form" model="ir.ui.view">
        <field name="name">taknia.advanced.accounting.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form string="Advanced Accounting Settings">
                <group string="AI & Recommendations">
                    <field name="chatgpt_api_key"/>
                    <field name="financial_advice_frequency"/>
                </group>

                <group string="Google Sheets Integration">
                    <field name="google_sheets_credentials"/>
                    <field name="google_sheets_sync_frequency"/>
                </group>

                <group string="Power BI Integration">
                    <field name="power_bi_workspace_id"/>
                    <field name="power_bi_dataset_id"/>
                    <field name="power_bi_api_key"/>
                </group>

                <group string="Bank Integration">
                    <field name="bank_api_url"/>
                    <field name="bank_api_key"/>
                    <field name="bank_sync_frequency"/>
                </group>

                <group string="Advanced Reports Settings">
                    <field name="default_report_currency"/>
                    <field name="default_branch_id"/>
                </group>
            </form>
        </field>
    </record>

    <record id="module_settings_action" model="ir.actions.act_window">
        <field name="name">Advanced Accounting Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_module_settings_form"/>
        <field name="target">inline</field>
    </record>

    <menuitem id="menu_module_settings"
              parent="taknia_advanced_accounting.menu_root"
              name="Module Settings"
              action="module_settings_action"
              sequence="100"/>

</odoo>
