<odoo>
    <record id="view_kpi_dashboard_form" model="ir.ui.view">
        <field name="name">kpi.dashboard.form</field>
        <field name="model">kpi.dashboard</field>
        <field name="arch" type="xml">
            <form string="Financial KPI Dashboard">
                <sheet>
                    <group>
                        <group string="General Information">
                            <field name="name"/>
                            <field name="date"/>
                            <field name="branch_id"/>
                        </group>
                    </group>
                    <group string="KPIs">
                        <group>
                            <field name="revenue"/>
                            <field name="expenses"/>
                            <field name="net_profit"/>
                            <field name="gross_margin"/>
                        </group>
                        <group>
                            <field name="current_ratio"/>
                            <field name="quick_ratio"/>
                            <field name="debt_to_equity"/>
                            <field name="cash_flow"/>
                        </group>
                    </group>
                    <group string="Financial Health">
                        <field name="health_score" widget="progressbar" options="{'max_value': 100}"/>
                        <field name="health_analysis" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kpi_dashboard_tree" model="ir.ui.view">
        <field name="name">kpi.dashboard.tree</field>
        <field name="model">kpi.dashboard</field>
        <field name="arch" type="xml">
            <tree string="Financial KPI Dashboard">
                <field name="name"/>
                <field name="date"/>
                <field name="branch_id"/>
                <field name="net_profit"/>
                <field name="gross_margin"/>
                <field name="health_score"/>
            </tree>
        </field>
    </record>

    <record id="action_kpi_dashboard" model="ir.actions.act_window">
        <field name="name">KPI Dashboard</field>
        <field name="res_model">kpi.dashboard</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p>
                This dashboard provides a comprehensive overview of your company's financial health, KPIs, and ratios.
                Use it to monitor performance across branches and time periods.
            </p>
        </field>
    </record>

    <menuitem id="menu_kpi_dashboard"
              parent="menu_financial_reports"
              action="action_kpi_dashboard"
              sequence="30"/>
</odoo>
