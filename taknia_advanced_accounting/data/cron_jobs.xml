<odoo>
    <data noupdate="1">

        <!-- Cron Job: توليد التقرير المالي الشهري تلقائياً -->
        <record id="ir_cron_generate_monthly_financial_report" model="ir.cron">
            <field name="name">توليد التقرير المالي الشهري</field>
            <field name="model_id" ref="model_financial_report"/>
            <field name="state">code</field>
            <field name="code">model.generate_monthly_report()</field>
            <field name="interval_type">months</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="active">True</field>
        </record>

        <!-- Cron Job: تحديث بيانات الذكاء الصناعي يومياً -->
        <record id="ir_cron_update_ai_recommendations" model="ir.cron">
            <field name="name">تحديث توصيات الذكاء الصناعي</field>
            <field name="model_id" ref="model_ai.recommendation"/>
            <field name="state">code</field>
            <field name="code">model.generate_ai_recommendations()</field>
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="active">True</field>
        </record>

        <!-- Cron Job: تحديث تقييم الصحة المالية كل أسبوع -->
        <record id="ir_cron_update_financial_health_score" model="ir.cron">
            <field name="name">تحديث تقييم الصحة المالية</field>
            <field name="model_id" ref="model_kpi.dashboard"/>
            <field name="state">code</field>
            <field name="code">model.update_financial_health_score()</field>
            <field name="interval_type">weeks</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="active">True</field>
        </record>

        <!-- Cron Job: تحديث بيانات التكامل مع Google Sheets أسبوعياً -->
        <record id="ir_cron_sync_google_sheets" model="ir.cron">
            <field name="name">مزامنة Google Sheets</field>
            <field name="model_id" ref="model_google.sheets.sync"/>
            <field name="state">code</field>
            <field name="code">model.sync_with_google_sheets()</field>
            <field name="interval_type">weeks</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
