<odoo>
    <record id="view_partner_ledger_wizard_form" model="ir.ui.view">
        <field name="name">partner.ledger.wizard.form</field>
        <field name="model">partner.ledger.wizard</field>
        <field name="arch" type="xml">
            <form string="Partner Ledger Report Wizard">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="branch_id"/>
                    <field name="partner_ids" widget="many2many_tags"/>
                    <field name="account_ids" widget="many2many_tags"/>
                    <field name="journal_ids" widget="many2many_tags"/>
                    <field name="currency_id"/>
                    <field name="show_details"/>
                    <field name="output_format" widget="selection"/>
                </group>
                <footer>
                    <button name="action_generate_partner_ledger" type="object" string="Generate Report" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_partner_ledger_wizard" model="ir.actions.act_window">
        <field name="name">Generate Partner Ledger Report</field>
        <field name="res_model">partner.ledger.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
