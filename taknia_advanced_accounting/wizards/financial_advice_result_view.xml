<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_financial_advice_result_form" model="ir.ui.view">
        <field name="name">financial.advice.result.form</field>
        <field name="model">financial.advice.result</field>
        <field name="arch" type="xml">
            <form string="Financial Advice">
                <group>
                    <field name="advice_text" nolabel="1"/>
                </group>
                <footer>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
