<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="partner_ledger_pdf_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="wizard">
                <t t-call="web.internal_layout">
                    <t t-set="doc" t-value="wizard"/>

                    <div class="page">
                        <h2>Partner Ledger Report</h2>
                        <p>
                            Period: <t t-esc="wizard.date_from"/> to <t t-esc="wizard.date_to"/>
                        </p>
                        <p t-if="wizard.branch_id">
                            Branch: <t t-esc="wizard.branch_id.name"/>
                        </p>

                        <table class="table table-condensed">
                            <thead>
                                <tr>
                                    <th>Partner</th>
                                    <th>Date</th>
                                    <th>Journal</th>
                                    <th>Account</th>
                                    <th>Debit</th>
                                    <th>Credit</th>
                                    <th>Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="report_data" t-value="doc._fetch_report_data(doc.get_report_data())"/>
                                <t t-foreach="report_data.items()" t-as="item">
                                    <t t-set="partner" t-value="item[0]"/>
                                    <t t-set="data" t-value="item[1]"/>
                                    <tr class="partner-header">
                                        <td colspan="7">
                                            <strong><t t-esc="partner.name or 'Unknown Partner'"/></strong>
                                        </td>
                                    </tr>
                                    <t t-foreach="data['lines']" t-as="line">
                                        <tr>
                                            <td></td>
                                            <td><t t-esc="line.date"/></td>
                                            <td><t t-esc="line.journal_id.name"/></td>
                                            <td><t t-esc="line.account_id.code"/> - <t t-esc="line.account_id.name"/></td>
                                            <td><t t-esc="line.debit"/></td>
                                            <td><t t-esc="line.credit"/></td>
                                            <td><t t-esc="line.debit - line.credit"/></td>
                                        </tr>
                                    </t>
                                    <tr class="partner-total">
                                        <td colspan="4"><strong>Total for <t t-esc="partner.name"/></strong></td>
                                        <td><strong><t t-esc="data['debit']"/></strong></td>
                                        <td><strong><t t-esc="data['credit']"/></strong></td>
                                        <td><strong><t t-esc="data['balance']"/></strong></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
