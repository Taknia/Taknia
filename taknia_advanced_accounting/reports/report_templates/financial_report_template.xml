<odoo>
    <template id="financial_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2 style="text-align: center;">📊 التقرير المالي المتقدم</h2>
                    <h4 style="text-align: center;">🔹 الفرع: <t t-esc="doc.branch_id.name or 'كل الفروع'"/></h4>
                    <h4 style="text-align: center;">🔹 الفترة: من <t t-esc="doc.date_from"/> إلى <t t-esc="doc.date_to"/></h4>

                    <table class="table table-bordered" style="width: 100%; text-align: center; margin-top: 20px;">
                        <thead style="background-color: #f0f0f0;">
                            <tr>
                                <th>كود الحساب</th>
                                <th>اسم الحساب</th>
                                <th>الرصيد الافتتاحي</th>
                                <th>مدين</th>
                                <th>دائن</th>
                                <th>الرصيد الختامي</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="doc.line_ids" t-as="line">
                                <tr>
                                    <td><t t-esc="line.account_id.code"/></td>
                                    <td><t t-esc="line.account_id.name"/></td>
                                    <td><t t-esc="line.initial_balance" /></td>
                                    <td><t t-esc="line.debit" /></td>
                                    <td><t t-esc="line.credit" /></td>
                                    <td><t t-esc="line.ending_balance" /></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div style="margin-top: 20px; text-align: right; font-weight: bold;">
                        🔹 إجمالي المدين: <t t-esc="doc.total_debit"/> 
                        🔹 إجمالي الدائن: <t t-esc="doc.total_credit"/> 
                        🔹 إجمالي الرصيد الختامي: <t t-esc="doc.total_ending_balance"/>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
