<odoo>
    <template id="accounting_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2 style="text-align: center;">Accounting Report</h2>
                    <h4 style="text-align: center;">
                        <t t-esc="o.date_from"/> to <t t-esc="o.date_to"/>
                    </h4>

                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Account</th>
                                <th>Debit</th>
                                <th>Credit</th>
                                <th>Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o._get_report_lines()" t-as="line">
                                <tr>
                                    <td><t t-esc="line['account']"/></td>
                                    <td><t t-esc="line['debit']"/></td>
                                    <td><t t-esc="line['credit']"/></td>
                                    <td><t t-esc="line['balance']"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
