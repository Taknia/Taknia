<odoo>
    <record id="view_partner_ledger_wizard" model="ir.ui.view">
        <field name="name">partner.ledger.wizard.form</field>
        <field name="model">partner.ledger.wizard</field>
        <field name="arch" type="xml">
            <form string="Partner Ledger Filters">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="branch_id"/>
                    <field name="partner_id"/>
                    <field name="currency_id"/>
                </group>
                <footer>
                    <button string="Print Report" type="object" name="action_print_report" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
