<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- تعريف الإجراء لتقرير الصحة المالية للفروع -->
        <record id="action_branch_financial_health_report" model="ir.actions.act_window">
            <field name="name">Branch Financial Health Report</field>
            <field name="res_model">branch.financial.health.report</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_branch_financial_health_report"/>
            <field name="context">{}</field>
        </record>

        <!-- تعريف الإجراء للتقرير داخل قائمة التقارير -->
        <record id="action_branch_financial_health_report_menu" model="ir.actions.act_window">
            <field name="name">Branch Financial Health Reports</field>
            <field name="res_model">branch.financial.health.report</field>
            <field name="view_mode">tree,form</field>
            <field name="target">current</field>
            <field name="context">{}</field>
        </record>

        <!-- إضافة التقرير إلى القائمة -->
        <menuitem id="branch_financial_health_report_menu"
                  name="Branch Financial Health"
                  parent="taknia_branch_management.menu_reports"
                  action="action_branch_financial_health_report_menu"
                  sequence="20"/>

        <!-- تعريف زر الإجراء لطباعة التقرير -->
        <record id="action_branch_financial_health_report_print" model="ir.actions.report">
            <field name="name">Branch Financial Health Report</field>
            <field name="model">branch.financial.health.report</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">taknia_branch_management.report_branch_financial_health</field>
            <field name="report_file">taknia_branch_management.report_branch_financial_health</field>
            <field name="binding_model_id" ref="model_branch_financial_health_report"/>
        </record>

    </data>
</odoo>
