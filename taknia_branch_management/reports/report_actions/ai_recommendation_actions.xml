<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- تعريف الإجراء لتقرير توصيات الذكاء الصناعي -->
        <record id="action_ai_recommendation_report" model="ir.actions.act_window">
            <field name="name">AI Recommendations Report</field>
            <field name="res_model">ai.recommendation.report</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_ai_recommendation_report"/>
            <field name="context">{}</field>
        </record>

        <!-- تعريف الإجراء للتقرير داخل قائمة التقارير -->
        <record id="action_ai_recommendation_report_menu" model="ir.actions.act_window">
            <field name="name">AI Recommendations</field>
            <field name="res_model">ai.recommendation.report</field>
            <field name="view_mode">tree,form</field>
            <field name="target">current</field>
            <field name="context">{}</field>
        </record>

        <!-- إضافة التقرير إلى القائمة -->
        <menuitem id="ai_recommendation_report_menu"
                  name="AI Recommendations"
                  parent="taknia_branch_management.menu_reports"
                  action="action_ai_recommendation_report_menu"
                  sequence="80"/>

        <!-- تعريف زر الإجراء لطباعة التقرير -->
        <record id="action_ai_recommendation_report_print" model="ir.actions.report">
            <field name="name">AI Recommendations Report</field>
            <field name="model">ai.recommendation.report</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">taknia_branch_management.report_ai_recommendation</field>
            <field name="report_file">taknia_branch_management.report_ai_recommendation</field>
            <field name="binding_model_id" ref="model_ai_recommendation_report"/>
        </record>

    </data>
</odoo>
