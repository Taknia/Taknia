<odoo>
    <template id="branch_scoring_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>Branch Scoring Report</h2>
                    <p>Branch: <t t-esc="doc.branch_id.name"/></p>
                    <p>Score: <t t-esc="doc.score"/></p>
                    <p>Date: <t t-esc="doc.date"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>