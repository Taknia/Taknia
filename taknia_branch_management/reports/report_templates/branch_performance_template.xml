<odoo>
    <template id="branch_performance_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>Branch Performance Report</h2>
                    <p>Branch: <t t-esc="doc.branch_id.name"/></p>
                    <p>KPI: <t t-esc="doc.kpi"/></p>
                    <p>Value: <t t-esc="doc.value"/></p>
                    <p>Date: <t t-esc="doc.date"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>