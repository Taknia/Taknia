<odoo>
    <template id="report_branch_performance">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>Branch Performance Report</h2>
                    <p>Branch: <span t-field="doc.branch_id.name"/></p>
                    <p>Date: <span t-field="doc.date"/></p>
                    <p>Revenue: <span t-field="doc.revenue"/></p>
                    <p>Expenses: <span t-field="doc.expenses"/></p>
                    <p>Profit: <span t-field="doc.profit"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>