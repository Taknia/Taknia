<odoo>
    <template id="report_branch_expense_analysis">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>Branch Expense Analysis Report</h2>
                    <p>Branch: <span t-field="doc.branch_id.name"/></p>
                    <p>Expense Category: <span t-field="doc.expense_category"/></p>
                    <p>Amount: <span t-field="doc.amount"/></p>
                    <p>Date: <span t-field="doc.date"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>