<odoo>
    <template id="branch_financial_health_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>Branch Financial Health Report</h2>
                    <p>Branch: <t t-esc="doc.branch_id.name"/></p>
                    <p>Financial Health Data: <t t-esc="doc.financial_health_data"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>