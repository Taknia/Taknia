<odoo>
    <template id="report_branch_financial_health">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>Branch Financial Health Report</h2>
                    <p>Branch: <span t-field="doc.branch_id.name"/></p>
                    <p>Date: <span t-field="doc.date"/></p>
                    <p>Financial Metric: <span t-field="doc.financial_metric"/></p>
                    <p>Value: <span t-field="doc.value"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>