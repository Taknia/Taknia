<odoo>
    <template id="report_branch_customer_analysis">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>Branch Customer Analysis Report</h2>
                    <p>Branch: <span t-field="doc.branch_id.name"/></p>
                    <p>Customer Segment: <span t-field="doc.customer_segment"/></p>
                    <p>Analysis Data: <span t-field="doc.analysis_data"/></p>
                    <p>Date: <span t-field="doc.date"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>