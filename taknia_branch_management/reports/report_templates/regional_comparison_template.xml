<odoo>
    <template id="regional_comparison_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>Regional Comparison Report</h2>
                    <p>Region: <t t-esc="doc.region_name"/></p>
                    <p>Branches: <t t-esc="doc.branch_count"/></p>
                    <table class="table table-condensed">
                        <thead>
                            <tr>
                                <th>Branch Name</th>
                                <th>Performance</th>
                                <th>Revenue</th>
                                <th>Expenses</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="doc.branch_details" t-as="branch">
                                <tr>
                                    <td><t t-esc="branch.name"/></td>
                                    <td><t t-esc="branch.performance"/></td>
                                    <td><t t-esc="branch.revenue"/></td>
                                    <td><t t-esc="branch.expenses"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <p>Total Revenue: <t t-esc="doc.total_revenue"/></p>
                    <p>Total Expenses: <t t-esc="doc.total_expenses"/></p>
                    <p>Net Profit: <t t-esc="doc.net_profit"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>