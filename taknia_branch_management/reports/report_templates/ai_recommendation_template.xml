<odoo>
    <template id="ai_recommendation_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>AI Branch Advisor Recommendations</h2>
                    <p>Branch: <t t-esc="doc.branch_id.name"/></p>
                    <p>Advice: <t t-esc="doc.advice"/></p>
                    <p>Date: <t t-esc="doc.date"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>