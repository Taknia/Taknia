<odoo>
    <template id="report_ai_recommendation">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>AI Recommendation Report</h2>
                    <p>Branch: <span t-field="doc.branch_id.name"/></p>
                    <p>Advice: <span t-field="doc.advice"/></p>
                    <p>Date: <span t-field="doc.date"/></p>
                </div>
            </t>
        </t>
    </template>
</odoo>