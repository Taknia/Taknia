<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Branch Sequence -->
        <record id="seq_branch_code" model="ir.sequence">
            <field name="name">Branch Code</field>
            <field name="code">taknia.branch.sequence</field>
            <field name="prefix">BR/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Region Sequence -->
        <record id="seq_region_code" model="ir.sequence">
            <field name="name">Region Code</field>
            <field name="code">taknia.region.sequence</field>
            <field name="prefix">RG/%(year)s/</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
