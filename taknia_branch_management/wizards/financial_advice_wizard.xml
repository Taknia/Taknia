<odoo>
    <record id="view_financial_advice_wizard_form" model="ir.ui.view">
        <field name="name">financial.advice.wizard.form</field>
        <field name="model">financial.advice.wizard</field>
        <field name="arch" type="xml">
            <form string="Financial Advice Wizard">
                <sheet>
                    <group>
                        <field name="branch_id"/>
                        <field name="advice"/>
                    </group>
                    <footer>
                        <button string="Submit" type="object" name="submit_advice" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>