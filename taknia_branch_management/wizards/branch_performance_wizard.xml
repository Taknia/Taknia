<odoo>
    <record id="view_branch_performance_wizard_form" model="ir.ui.view">
        <field name="name">branch.performance.wizard.form</field>
        <field name="model">branch.performance.wizard</field>
        <field name="arch" type="xml">
            <form string="Branch Performance Wizard">
                <sheet>
                    <group>
                        <field name="branch_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                    <footer>
                        <button string="Generate Report" type="object" name="generate_report" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>