<odoo>
    <record id="view_branch_performance_wizard_form" model="ir.ui.view">
        <field name="name">branch.performance.wizard.form</field>
        <field name="model">branch.performance.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="branch_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <button string="Generate Report" type="object" name="generate_report"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_branch_performance_wizard" model="ir.actions.act_window">
        <field name="name">Branch Performance Wizard</field>
        <field name="res_model">branch.performance.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>