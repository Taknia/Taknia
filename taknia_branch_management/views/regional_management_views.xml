<odoo>
    <record id="view_regional_management_form" model="ir.ui.view">
        <field name="name">regional.management.form</field>
        <field name="model">regional.management</field>
        <field name="arch" type="xml">
            <form string="Regional Management">
                <sheet>
                    <group>
                        <field name="region_name"/>
                        <field name="manager"/>
                        <field name="active"/>
                        <field name="branches" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_regional_management_tree" model="ir.ui.view">
        <field name="name">regional.management.tree</field>
        <field name="model">regional.management</field>
        <field name="arch" type="xml">
            <tree string="Regional Management">
                <field name="region_name"/>
                <field name="manager"/>
                <field name="active"/>
                <field name="branches"/>
            </tree>
        </field>
    </record>

    <record id="action_regional_management" model="ir.actions.act_window">
        <field name="name">Regional Management</field>
        <field name="res_model">regional.management</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>