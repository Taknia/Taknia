<odoo>
    <record id="view_branch_kpi_dashboard_tree" model="ir.ui.view">
        <field name="name">branch.kpi.dashboard.tree</field>
        <field name="model">branch.kpi.dashboard</field>
        <field name="arch" type="xml">
            <tree>
                <field name="branch_id"/>
                <field name="kpi_name"/>
                <field name="kpi_value"/>
                <field name="target_value"/>
                <field name="date"/>
            </tree>
        </field>
    </record>

    <record id="view_branch_kpi_dashboard_form" model="ir.ui.view">
        <field name="name">branch.kpi.dashboard.form</field>
        <field name="model">branch.kpi.dashboard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="branch_id"/>
                        <field name="kpi_name"/>
                        <field name="kpi_value"/>
                        <field name="target_value"/>
                        <field name="date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_branch_kpi_dashboard" model="ir.actions.act_window">
        <field name="name">KPI Dashboard</field>
        <field name="res_model">branch.kpi.dashboard</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>