<odoo>
    <record id="view_kpi_dashboard_form" model="ir.ui.view">
        <field name="name">kpi.dashboard.form</field>
        <field name="model">branch.kpi.dashboard</field>
        <field name="arch" type="xml">
            <form string="KPI Dashboard">
                <sheet>
                    <group>
                        <field name="branch_id"/>
                        <field name="kpi_data"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kpi_dashboard_tree" model="ir.ui.view">
        <field name="name">kpi.dashboard.tree</field>
        <field name="model">branch.kpi.dashboard</field>
        <field name="arch" type="xml">
            <tree string="KPI Dashboard">
                <field name="branch_id"/>
                <field name="kpi_data"/>
            </tree>
        </field>
    </record>

    <record id="action_kpi_dashboard" model="ir.actions.act_window">
        <field name="name">KPI Dashboard</field>
        <field name="res_model">branch.kpi.dashboard</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>