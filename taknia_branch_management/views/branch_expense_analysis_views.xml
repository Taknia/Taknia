<odoo>
    <record id="view_branch_expense_analysis_tree" model="ir.ui.view">
        <field name="name">branch.expense.analysis.tree</field>
        <field name="model">branch.expense.analysis</field>
        <field name="arch" type="xml">
            <tree>
                <field name="branch_id"/>
                <field name="expense_category"/>
                <field name="amount"/>
                <field name="date"/>
            </tree>
        </field>
    </record>

    <record id="view_branch_expense_analysis_form" model="ir.ui.view">
        <field name="name">branch.expense.analysis.form</field>
        <field name="model">branch.expense.analysis</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="branch_id"/>
                        <field name="expense_category"/>
                        <field name="amount"/>
                        <field name="date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_branch_expense_analysis" model="ir.actions.act_window">
        <field name="name">Expense Analysis</field>
        <field name="res_model">branch.expense.analysis</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>