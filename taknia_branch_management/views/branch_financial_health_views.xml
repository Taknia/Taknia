<odoo>
    <record id="view_branch_financial_health_tree" model="ir.ui.view">
        <field name="name">branch.financial.health.tree</field>
        <field name="model">branch.financial.health</field>
        <field name="arch" type="xml">
            <tree>
                <field name="branch_id"/>
                <field name="financial_metric"/>
                <field name="value"/>
                <field name="date"/>
            </tree>
        </field>
    </record>

    <record id="view_branch_financial_health_form" model="ir.ui.view">
        <field name="name">branch.financial.health.form</field>
        <field name="model">branch.financial.health</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="branch_id"/>
                        <field name="financial_metric"/>
                        <field name="value"/>
                        <field name="date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_branch_financial_health" model="ir.actions.act_window">
        <field name="name">Financial Health</field>
        <field name="res_model">branch.financial.health</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>