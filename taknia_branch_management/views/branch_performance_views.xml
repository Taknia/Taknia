<odoo>
    <record id="view_branch_performance_form" model="ir.ui.view">
        <field name="name">branch.performance.form</field>
        <field name="model">branch.performance</field>
        <field name="arch" type="xml">
            <form string="Branch Performance">
                <sheet>
                    <group>
                        <field name="branch_id"/>
                        <field name="kpi"/>
                        <field name="value"/>
                        <field name="date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_branch_performance_tree" model="ir.ui.view">
        <field name="name">branch.performance.tree</field>
        <field name="model">branch.performance</field>
        <field name="arch" type="xml">
            <tree string="Branch Performance">
                <field name="branch_id"/>
                <field name="kpi"/>
                <field name="value"/>
                <field name="date"/>
            </tree>
        </field>
    </record>

    <record id="action_branch_performance" model="ir.actions.act_window">
        <field name="name">Branch Performance</field>
        <field name="res_model">branch.performance</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>