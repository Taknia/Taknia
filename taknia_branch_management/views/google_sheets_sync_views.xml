<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_google_sheets_sync_form" model="ir.ui.view">
        <field name="name">branch.google.sheets.sync.form</field>
        <field name="model">branch.google.sheets.sync</field>
        <field name="arch" type="xml">
            <form string="Google Sheets Synchronization">
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="google_credentials" filename="google_credentials_filename"/>
                        <field name="branch_ids" widget="many2many_tags"/>
                        <field name="last_sync_date" readonly="1"/>
                        <field name="sync_status" readonly="1"/>
                        <field name="spreadsheet_url" readonly="1"/>
                    </group>
                    <footer>
                        <button name="action_sync_with_google_sheets" type="object" string="Sync Now" class="oe_highlight"/>
                        <button name="action_open_google_sheet" type="object" string="Open Google Sheet" attrs="{'invisible': [('spreadsheet_url', '=', False)]}"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_google_sheets_sync_tree" model="ir.ui.view">
        <field name="name">branch.google.sheets.sync.tree</field>
        <field name="model">branch.google.sheets.sync</field>
        <field name="arch" type="xml">
            <tree string="Google Sheets Syncs">
                <field name="name"/>
                <field name="sync_status"/>
                <field name="last_sync_date"/>
                <field name="spreadsheet_url"/>
            </tree>
        </field>
    </record>

    <menuitem id="menu_google_sheets_sync_root" name="Google Sheets Sync" parent="taknia_branch_management.menu_branch_root"/>

    <record id="action_google_sheets_sync" model="ir.actions.act_window">
        <field name="name">Google Sheets Sync</field>
        <field name="res_model">branch.google.sheets.sync</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_google_sheets_sync" name="Google Sheets Sync" parent="menu_google_sheets_sync_root" action="action_google_sheets_sync"/>
</odoo>
