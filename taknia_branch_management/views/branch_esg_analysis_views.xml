<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- تعريف قائمة القوائم -->
        <menuitem id="taknia_branch_management_menu" name="Taknia Branch Management" sequence="10"/>
        
        <!-- قائمة فرعية لتحليل الاستدامة ESG -->
        <menuitem id="taknia_branch_esg_analysis_menu" name="ESG Analysis" parent="taknia_branch_management_menu" sequence="50"/>

        <!-- نافذة عرض تقرير تحليل الاستدامة ESG -->
        <record id="view_branch_esg_analysis_form" model="ir.ui.view">
            <field name="name">branch.esg.analysis.form</field>
            <field name="model">taknia.branch.esg.analysis</field>
            <field name="arch" type="xml">
                <form string="Branch ESG Analysis">
                    <sheet>
                        <group>
                            <!-- حقل الفرع -->
                            <field name="branch_id" required="1"/>
                            
                            <!-- حقل التاريخ -->
                            <field name="date" default="context_today()"/>
                            
                            <!-- حقل تحليل الاستدامة البيئية -->
                            <field name="environmental_analysis" readonly="1" widget="html"/>
                            
                            <!-- حقل تحليل الاستدامة الاجتماعية -->
                            <field name="social_analysis" readonly="1" widget="html"/>
                            
                            <!-- حقل تحليل الحوكمة -->
                            <field name="governance_analysis" readonly="1" widget="html"/>
                            
                            <!-- حقل التقييم الإجمالي للاستدامة ESG -->
                            <field name="overall_esg_score" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- نافذة قائمة تحليل الاستدامة ESG -->
        <record id="view_branch_esg_analysis_tree" model="ir.ui.view">
            <field name="name">branch.esg.analysis.tree</field>
            <field name="model">taknia.branch.esg.analysis</field>
            <field name="arch" type="xml">
                <tree string="Branch ESG Analysis">
                    <field name="branch_id"/>
                    <field name="date"/>
                    <field name="environmental_analysis"/>
                    <field name="social_analysis"/>
                    <field name="governance_analysis"/>
                    <field name="overall_esg_score"/>
                </tree>
            </field>
        </record>

        <!-- إنشاء القائمة الفرعية لعرض تحليل الاستدامة ESG -->
        <act_window id="action_branch_esg_analysis"
            name="ESG Analysis"
            res_model="taknia.branch.esg.analysis"
            view_mode="tree,form"
            menu_id="taknia_branch_esg_analysis_menu"/>
        
    </data>
</odoo>
