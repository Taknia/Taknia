<odoo>
    <record id="view_branch_budget_tree" model="ir.ui.view">
        <field name="name">branch.budget.tree</field>
        <field name="model">branch.budget</field>
        <field name="arch" type="xml">
            <tree>
                <field name="branch_id"/>
                <field name="fiscal_year"/>
                <field name="budget_amount"/>
                <field name="actual_amount"/>
                <field name="variance"/>
            </tree>
        </field>
    </record>

    <record id="view_branch_budget_form" model="ir.ui.view">
        <field name="name">branch.budget.form</field>
        <field name="model">branch.budget</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="branch_id"/>
                        <field name="fiscal_year"/>
                        <field name="budget_amount"/>
                        <field name="actual_amount"/>
                        <field name="variance"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_branch_budget" model="ir.actions.act_window">
        <field name="name">Branch Budget</field>
        <field name="res_model">branch.budget</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>