<odoo>
    <record id="view_branch_tree" model="ir.ui.view">
        <field name="name">branch.tree</field>
        <field name="model">branch</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="manager_id"/>
                <field name="address"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_branch_form" model="ir.ui.view">
        <field name="name">branch.form</field>
        <field name="model">branch</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="manager_id"/>
                        <field name="address"/>
                        <field name="phone"/>
                        <field name="email"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_branch" model="ir.actions.act_window">
        <field name="name">Branches</field>
        <field name="res_model">branch</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>