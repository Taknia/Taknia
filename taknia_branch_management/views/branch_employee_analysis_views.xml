<odoo>
    <record id="view_branch_employee_analysis_tree" model="ir.ui.view">
        <field name="name">branch.employee.analysis.tree</field>
        <field name="model">branch.employee.analysis</field>
        <field name="arch" type="xml">
            <tree>
                <field name="branch_id"/>
                <field name="employee_id"/>
                <field name="analysis_data"/>
                <field name="date"/>
            </tree>
        </field>
    </record>

    <record id="view_branch_employee_analysis_form" model="ir.ui.view">
        <field name="name">branch.employee.analysis.form</field>
        <field name="model">branch.employee.analysis</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="branch_id"/>
                        <field name="employee_id"/>
                        <field name="analysis_data"/>
                        <field name="date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_branch_employee_analysis" model="ir.actions.act_window">
        <field name="name">Employee Analysis</field>
        <field name="res_model">branch.employee.analysis</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>