<odoo>
    <record id="view_branch_power_bi_sync_form" model="ir.ui.view">
        <field name="name">branch.power.bi.sync.form</field>
        <field name="model">branch.power.bi.sync</field>
        <field name="arch" type="xml">
            <form string="Branch Power BI Sync">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="branch_ids" widget="many2many_tags"/>
                        <field name="dataset_id"/>
                        <field name="access_token" password="True"/>
                        <field name="last_sync_date" readonly="1"/>
                        <field name="sync_status" readonly="1"/>
                    </group>
                    <footer>
                        <button name="action_sync_with_power_bi" type="object" string="Sync Now" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_branch_power_bi_sync_tree" model="ir.ui.view">
        <field name="name">branch.power.bi.sync.tree</field>
        <field name="model">branch.power.bi.sync</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="branch_ids"/>
                <field name="last_sync_date"/>
                <field name="sync_status"/>
            </tree>
        </field>
    </record>

    <menuitem id="menu_power_bi_sync" name="Power BI Sync"
        parent="taknia_branch_management.menu_root"
        action="action_branch_power_bi_sync"/>

    <record id="action_branch_power_bi_sync" model="ir.actions.act_window">
        <field name="name">Power BI Sync</field>
        <field name="res_model">branch.power.bi.sync</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
