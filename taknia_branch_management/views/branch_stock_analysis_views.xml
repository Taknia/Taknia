<odoo>
    <record id="view_branch_stock_analysis_form" model="ir.ui.view">
        <field name="name">branch.stock.analysis.form</field>
        <field name="model">branch.stock.analysis</field>
        <field name="arch" type="xml">
            <form string="Branch Stock Analysis">
                <sheet>
                    <group>
                        <field name="branch_id"/>
                        <field name="stock_data"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_branch_stock_analysis_tree" model="ir.ui.view">
        <field name="name">branch.stock.analysis.tree</field>
        <field name="model">branch.stock.analysis</field>
        <field name="arch" type="xml">
            <tree string="Branch Stock Analysis">
                <field name="branch_id"/>
                <field name="stock_data"/>
            </tree>
        </field>
    </record>

    <record id="action_branch_stock_analysis" model="ir.actions.act_window">
        <field name="name">Branch Stock Analysis</field>
        <field name="res_model">branch.stock.analysis</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>