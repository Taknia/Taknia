<odoo>
    <record id="view_ai_branch_advisor_tree" model="ir.ui.view">
        <field name="name">ai.branch.advisor.tree</field>
        <field name="model">ai.branch.advisor</field>
        <field name="arch" type="xml">
            <tree>
                <field name="branch_id"/>
                <field name="advice"/>
                <field name="date"/>
            </tree>
        </field>
    </record>

    <record id="view_ai_branch_advisor_form" model="ir.ui.view">
        <field name="name">ai.branch.advisor.form</field>
        <field name="model">ai.branch.advisor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="branch_id"/>
                        <field name="advice"/>
                        <field name="date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_branch_advisor" model="ir.actions.act_window">
        <field name="name">AI Branch Advisor</field>
        <field name="res_model">ai.branch.advisor</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>