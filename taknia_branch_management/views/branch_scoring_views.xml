<odoo>
    <record id="view_branch_scoring_tree" model="ir.ui.view">
        <field name="name">branch.scoring.tree</field>
        <field name="model">branch.scoring</field>
        <field name="arch" type="xml">
            <tree>
                <field name="branch_id"/>
                <field name="score"/>
                <field name="date"/>
            </tree>
        </field>
    </record>

    <record id="view_branch_scoring_form" model="ir.ui.view">
        <field name="name">branch.scoring.form</field>
        <field name="model">branch.scoring</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="branch_id"/>
                        <field name="score"/>
                        <field name="date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_branch_scoring" model="ir.actions.act_window">
        <field name="name">Branch Scoring</field>
        <field name="res_model">branch.scoring</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>